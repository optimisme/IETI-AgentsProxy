{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ieti-agents": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "IETI Agents",
      "options": {
        "baseURL": "http://127.0.0.1:3100/v1",
        "apiKey": "{env:IETI_AGENT_KEY}",
        "timeout": 900000,
        "chunkTimeout": 600000
      },
      "models": {
        "active-model": {
          "name": "Active Model",
          "limit": {
            "context": 65536,
            "output": 8192
          },
          "max_tokens": 8192,
          "tool_call": true,
          "reasoning": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  },
  "model": "ieti-agents/active-model"
}
