{
  "name": "ieti-agents-deepseek-proxy",
  "version": "1.0.0",
  "description": "OpenAI-compatible DeepSeek proxy for educational AI agents courses",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "init-db": "node src/db/init.js",
    "test": "node --test test/*.test.js",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop app",
    "pm2:restart": "pm2 restart app --update-env",
    "pm2:delete": "pm2 delete app",
    "pm2:list": "pm2 list",
    "pm2:logs": "pm2 logs app",
    "pm2:save": "pm2 save"
  },
  "keywords": [
    "openai-compatible",
    "deepseek",
    "proxy",
    "education"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "better-sqlite3-session-store": "^0.1.0",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "express-session": "^1.19.0",
    "helmet": "^8.2.0"
  },
  "devDependencies": {
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=24 <25"
  }
}
