# Copy this file to settings.env and replace the dummy values before running in production.
# Never commit settings.env.

# Server
PORT=3000
DATABASE_PATH=./data/agents_proxy.sqlite

# Initial upstream provider seed.
# These values are only used when creating the first provider in an empty database.
DEEPSEEK_API_KEY=dummy_provider_api_key_replace_me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEFAULT_PROVIDER_SLUG=deepseek
DEFAULT_PROVIDER_NAME=DeepSeek
DEFAULT_UPSTREAM_MODEL=deepseek-chat

# Public OpenAI-compatible model exposed by this proxy.
PUBLIC_MODEL_NAME=active-model

# Optional. Leave empty to auto-detect from the current request host.
# Example: https://agents.example.edu
PUBLIC_BASE_URL=

# Admin authentication.
# Prefer ADMIN_PASSWORD_HASH in production. If it is set, ADMIN_PASSWORD is ignored.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=dummy_admin_password_replace_me
ADMIN_PASSWORD_HASH=

# Express session signing secret. Use a long random value in production.
SESSION_SECRET=dummy_long_random_session_secret_replace_me

# Limits
MAX_REQUESTS_PER_MINUTE=1000
MAX_TOKENS_PER_REQUEST=131072
DEFAULT_DAILY_TOKEN_LIMIT=10000000
DEFAULT_MODEL_CONTEXT_LIMIT=131072
DEFAULT_MODEL_OUTPUT_LIMIT=8192
MAX_IMAGES_PER_REQUEST=4
MAX_IMAGE_BYTES=8000000
MAX_TOTAL_IMAGE_BYTES=16000000
ALLOW_VIDEO_INPUT=false

# Runtime behavior
ENABLE_STREAMING=true
LOG_REQUEST_BODY=false
REQUEST_TIMEOUT_MS=120000
